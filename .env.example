# ============================================================
# BFD-setter — Environment Variables
# Copy this file to `.env` and fill in your values from the vault.
# NEVER commit `.env` (it's gitignored). Run scripts with:
#   node --env-file=.env scripts/<name>.mjs
#
# SCOPE (important, verified 2026-07-20):
#   PART 1 below is what this file is FOR: credentials for the local
#   scripts in scripts/ and scripts/test-harness/. Filling these in does
#   NOT configure a running system.
#   PART 2 is a REFERENCE list of the 31 variables the deployed code
#   actually reads at runtime. Those are set in the Supabase, Trigger.dev
#   and Railway dashboards, NOT here. They are listed so an operator can
#   see what exists; previously this file documented none of them.
# ============================================================


# ============================================================
# PART 1 — LOCAL SCRIPT CREDENTIALS (fill these in)
# ============================================================

# ── Supabase: bfd-platform (main backend DB) ────────────────
# Dashboard → Project Settings → API
BFD_PLATFORM_URL=https://bjgrgbgykvjrsuwwruoh.supabase.co
# New `sb_secret_*` key (legacy JWT system disabled).
BFD_PLATFORM_SECRET_KEY=

# ── Supabase: account-level Management API PAT ──────────────
# https://supabase.com/dashboard/account/tokens
# Used by scripts to run arbitrary SQL via the Management API.
# This is the canonical way to read the live DB (NOT the postgres MCP).
SUPABASE_PAT=

# ── Trigger.dev ──────────────────────────────────────────────
# Runtime token (also read by edge functions in the deployed env — the ONLY
# key in this file that deployed runtime code reads):
#   Dashboard → Project → API Keys → "PROD" environment
TRIGGER_SECRET_KEY=
# Deploy PAT (used ONLY by the deploy CLI, as
# `TRIGGER_ACCESS_TOKEN=$TRIGGER_DEPLOY_PAT npx trigger.dev deploy`):
#   https://cloud.trigger.dev/account/tokens
TRIGGER_DEPLOY_PAT=

# ── Retell AI (BFD client) ───────────────────────────────────
# Dashboard → API Keys
BFD_RETELL_API_KEY=
# WARNING: the two ids below are STALE. `llm_22e795...` refers to a DELETED
# Retell LLM (scripts/deploy_voice_prompt.mjs:20 carries the same stale
# fallback and says so). Do not treat them as the live agent/LLM. To find
# which agent actually serves a direction, read `voice_setters.retell_agent_id`
# from the live DB — never trust a hardwired id or a phone-number binding.
BFD_RETELL_LLM_ID=llm_22e795de19b4d25cb579013586be
BFD_RETELL_AGENT_ID=agent_5ec5eb129f3165cfa07b581a1a

# ── BFD platform identifiers (not secrets, but useful) ──────
BFD_CLIENT_ID=e467dabc-57ee-416c-8831-83ecd9c7c925

# ── GoHighLevel (BFD client) ─────────────────────────────────
# GHL → Settings → Private Integration Tokens
# NOTE: BFD_GHL_PIT was recorded as stale/401 (Docs/archive/COMPLETED_LOG.md).
# Re-issue before relying on it.
BFD_GHL_PIT=
# DISCREPANCY (flagged 2026-07-20, NOT auto-corrected): this value is the
# BFD *calendar* id per Docs/WEBHOOKS.md §G, which lists
# locationId = xo0XjmenBBJxJgSnAdyM and calendarId = 2p9eg0Qv7QoKknk1Sp2d.
# One of the two docs is wrong. Verify against clients.ghl_location_id
# before using. No live code reads this var, so nothing is currently broken.
BFD_GHL_LOCATION_ID=2p9eg0Qv7QoKknk1Sp2d

# ── Test-harness only (scripts/test-harness/) ────────────────
# These drive LIVE production: real SMS, real outbound calls. See
# scripts/test-harness/README.md before using.
# Twilio creds: the LIVE account credentials are stored in the `clients`
# table, not here. The keys below were kept for older scripts and no
# runtime code reads them.
BFD_TWILIO_ACCOUNT_SID=
BFD_TWILIO_AUTH_TOKEN=
BFD_TWILIO_PHONE=+61481614530

# ── OBSOLETE (kept only so their absence is not mistaken for a gap) ──
# No code in the repo reads these. `bfd-setter-live` is the second Supabase
# project (qildpilxjodxdifggmto) whose purpose was already flagged as unclear
# in Operations/handoffs/2026-05-31-single-ingress-and-cleanup.md.
# BFD_SETTER_LIVE_URL=https://qildpilxjodxdifggmto.supabase.co
# BFD_SETTER_LIVE_SECRET_KEY=
# BFD_PLATFORM_PUBLISHABLE_KEY=


# ============================================================
# PART 2 — DEPLOYED RUNTIME CONFIG (reference only, set elsewhere)
# Do NOT expect to fill these in locally. Listed because the code reads
# them and nothing else documented them.
# ============================================================

# ── Supabase edge functions (set in Supabase → Edge Functions → Secrets) ──
# Injected automatically by the Supabase edge runtime:
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#   SUPABASE_PUBLISHABLE_KEY
# Set manually:
#   TRIGGER_SECRET_KEY              fire Trigger.dev tasks from edge fns
#   STRIPE_SECRET_KEY               stripe-checkout / stripe-portal
#   STRIPE_WEBHOOK_SECRET           stripe-webhook signature verification
#   GITHUB_PAT                      github-proxy
#   UNIPILE_API_KEY                 unipile-proxy
#   UNIPILE_DSN                     unipile-proxy
#   APP_BASE_URL                    deep links written back to GHL (sync-ghl-contact)
#   SITE_URL                        invite-client-user email links
# Feature flags / limits:
#   ENFORCE_SUBSCRIPTION_GATE       gates app access on subscription_status.
#                                   Currently OFF; flipping it is a
#                                   first-client-milestone step.
#   DM_WEBHOOK_REQUIRE_SECRET       receive-dm-webhook fail-closed switch.
#                                   Defaults to ENFORCED when unset; only set
#                                   it to false deliberately.
#   INTAKE_RATE_LIMIT_PER_MIN       intake-lead burst limit
#   ENROLL_RATE_LIMIT_PER_MIN       campaign-enroll-webhook burst limit
#   GHPROXY_RATE_LIMIT_PER_MIN      github-proxy burst limit

# ── Trigger.dev tasks (set in Trigger.dev → Environment Variables, PROD) ──
# NOTE: trigger/ uses process.env, not Deno.env. These are scoped to the
# Trigger.dev project separately from Supabase; a missing one throws at
# runtime before any DB write (memory feedback_trigger_env_var_audit).
#   SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
#   RESEND_API_KEY                  errorDigest email delivery
#   ERROR_DIGEST_RECIPIENT          errorDigest destination address
#   PROBE_ALERT_WEBHOOK_URL         syntheticProbe alerting
#   PROBE_CLIENT_ID                 syntheticProbe tenant
#   PROBE_INTAKE_SECRET             syntheticProbe intake-lead bearer
#   PROBE_TEST_PHONE                syntheticProbe target number.
#                                   Must NOT share retell_phone_1 with a real
#                                   client (memory feedback_probe_no_shared_phone).

# ── Frontend (Railway service env, Vite build-time) ──────────
# Vite inlines these at BUILD time, so changing one needs a rebuild.
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY
#   VITE_SUPABASE_PUBLISHABLE_KEY
#   VITE_AI_PROMPT_WEBHOOK_URL              legacy upstream webhooks; each
#   VITE_PROMPT_WEBHOOK_URL                 throws cleanly when unset, which
#   VITE_SETUP_GUIDE_PROMPT_WEBHOOK_URL     is the intended state now that
#   VITE_TEXT_CHAT_ANALYTICS_WEBHOOK_URL    n8n is decommissioned.
#   VITE_VOICE_CHAT_ANALYTICS_WEBHOOK_URL
#   VITE_COST_ESTIMATE_URL
