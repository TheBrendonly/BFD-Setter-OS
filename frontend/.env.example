# Frontend environment variables — Vite (build-time, exposed to the browser).
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored. NEVER commit real values to .env.example.
#
# All four vars point at the same Supabase project. They are required by
# different parts of the dashboard:
#   client.ts (the main supabase-js init) reads VITE_SUPABASE_URL +
#     VITE_SUPABASE_ANON_KEY.
#   Feature pages that hit edge functions directly (ApiCredentials,
#     twilioNumbers, CampaignDashboard, ContactConversationHistory,
#     DemoPageContactChat, EmailInbox, InstagramDMs, AttendeeAvatar,
#     AttendeeProfileDialog, RetellAgentsTab, VoiceRetellSettings) read
#     VITE_SUPABASE_PROJECT_ID + VITE_SUPABASE_PUBLISHABLE_KEY.
# A future cleanup will consolidate ANON_KEY and PUBLISHABLE_KEY to one name.
# Until then, both must hold the SAME publishable-key value.
#
# Find the values at: Supabase Dashboard → Project Settings → API.
# Use the new sb_publishable_* / sb_secret_* format — legacy JWT keys were
# disabled 2026-04-29.

# Project ref (the {ref} portion of https://{ref}.supabase.co)
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# Project URL (https://{ref}.supabase.co — full origin, no trailing slash)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable key (starts with sb_publishable_). Same value in both names below.
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
